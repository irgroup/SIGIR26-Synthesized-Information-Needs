// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "conf26-generate-topics",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
	"runArgs": [
		"--name",
		"conf26-generate-topics_${localEnv:USER}",
		"--gpus",
		"all",
		"--shm-size=32g",
		"--network=host"
	],
	"features": {
		"ghcr.io/devcontainers-extra/features/poetry:2": {
			"version": "2.0.1"
		}
	},
	"mounts": [
		"source=/mnt/datadisk2/projects_irg/jueri/resources/ir_datasets,target=/workspaces/${localWorkspaceFolderBasename}/data/raw/ir_datasets,type=bind",
		"source=/mnt/datadisk2/projects_irg/jueri/resources/datasets,target=/workspaces/${localWorkspaceFolderBasename}/data/raw/datasets,type=bind",
		"source=/mnt/datadisk2/projects_irg/jueri/resources/models,target=/workspaces/${localWorkspaceFolderBasename}/data/raw/models,type=bind"
	],
	"containerEnv": {
		"IR_DATASETS_HOME": "/workspaces/${localWorkspaceFolderBasename}/data/raw/ir_datasets",
		"IR_DATASETS_TMP": "/workspaces/${localWorkspaceFolderBasename}/data/raw/ir_datasets",
		"HF_HOME": "/workspaces/${localWorkspaceFolderBasename}/data/raw/models/huggingface"
	},
	"customizations": {
		// Configure properties specific to VS Code.
		"vscode": {
			// Set *default* container specific settings.json values on container create.
			"settings": {
				"editor.formatOnSave": true,
				"files.insertFinalNewline": true
			},
			// Add the IDs of extensions you want installed when the container is created.
			"extensions": [
				"ms-toolsai.jupyter",
				"ms-python.python",
				"ms-python.black-formatter"
			]
		}
	},
	"postCreateCommand": "poetry install --no-interaction --no-ansi --no-root"
	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],
	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "pip3 install --user -r requirements.txt",
	// Configure tool-specific properties.
	// "customizations": {},
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
